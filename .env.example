# =============================================================================
# GigAI Bharat — Environment Variables
# =============================================================================
# Copy to `.env.local` at repo root for local development.
# Per-app overrides: apps/worker/.env.local, apps/admin/.env.local
#
# NEVER commit real values. Rotate keys if exposed.
# =============================================================================

# --- App environment ---
APP_ENV=development
# development | staging | production | demo
# demo enables seeded earnings on signup (disable in production)

# --- Worker public demo (investor / pilot without full auth) ---
VITE_ALLOW_INVESTOR_DEMO=true

# --- Supabase (all apps that talk to backend) ---
VITE_SUPABASE_URL=https://ykrdwmbbieccfftierzc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_or_publishable_key
VITE_SUPABASE_PROJECT_ID=ykrdwmbbieccfftierzc
# Auth: allowlist https://app.bharatgig.live/auth/callback in Supabase Dashboard (see docs/AUTH_PRODUCTION.md)

# Admin only — server-side / CI only. NEVER prefix with VITE_
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Open map stack (MapLibre + OSM — no Google keys) ---
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark
VITE_MAP_DEFAULT_LAT=12.9716
VITE_MAP_DEFAULT_LNG=77.5946
VITE_MAP_DEFAULT_ZOOM=12
# Optional: override Edge Function URLs (defaults derived from VITE_SUPABASE_URL)
# VITE_GEO_PROXY_URL=
# VITE_ROUTE_PROXY_URL=
# VITE_EV_PROXY_URL=

# --- Supabase Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets) ---
OPENROUTESERVICE_API_KEY=          # https://openrouteservice.org/dev/#/signup — free 2K req/day
OPENCHARGEMAP_API_KEY=             # https://openchargemap.org/site/develop/api — free
DATA_GOV_IN_API_KEY=               # https://data.gov.in — India gov datasets (optional)
RATE_LIMIT_GEO_PER_MIN=30
GEOCODE_CACHE_TTL_SECONDS=86400
# LOVABLE_API_KEY=                 # legacy AI OCR — migrate to OpenRouter/Ollama
# OPENROUTER_API_KEY=              # optional free AI models
# SUPABASE_SERVICE_ROLE_KEY=       # auto-injected in Edge runtime; required for sync-chargers cron

# --- Marketing site (Vercel / TanStack Start) ---
# Optional: canonical URL for SEO (production domain)
# VITE_SITE_URL=https://www.bharatgig.live

# --- Marketing contact forms (server-only — set in Vercel, NOT VITE_) ---
# RESEND_API_KEY=re_xxxxxxxx                    # resend.com → API Keys
# EMAIL_FROM=GigAI Bharat <no-reply@bharatgig.live>
# CONTACT_ADMIN_NOTIFY=your-private@gmail.com   # Hidden BCC on all form submissions
# TURNSTILE_SECRET_KEY=                         # Cloudflare Turnstile (recommended prod)
# VITE_TURNSTILE_SITE_KEY=                      # Public Turnstile widget key

# See docs/EMAIL_SETUP.md for SPF/DKIM/DMARC DNS and Cloudflare Email Routing.

# --- Future AI services (infra/ai) ---
# OPENAI_API_KEY=
# AI_GATEWAY_URL=

# --- Observability (optional) ---
# Vercel Analytics: enable in Vercel Dashboard → Analytics (no env var needed)
# VITE_SENTRY_DSN=              # Worker Sentry DSN (sentry.io → React project)
# SENTRY_AUTH_TOKEN=            # CI source maps upload only

# --- Deployment (local CLI / GitHub Actions) ---
# CLOUDFLARE_API_TOKEN=
# VERCEL_TOKEN=
# VERCEL_ORG_ID=team_xxx
# VERCEL_MARKETING_PROJECT_ID=prj_8pk8D5inKD9wCnvmYG7bWklO6b55  # gigai-bharat-marketing
# VERCEL_WORKER_PROJECT_ID=prj_td8bpmue2FlTHOqrZ1RkAfU7PAUY     # gigai-bharat-worker
