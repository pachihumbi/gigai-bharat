{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npm run build -w @gigai/marketing",
  "framework": null,
  "build": {
    "env": {
      "VITE_SITE_URL": "https://www.bharatgig.live",
      "DEPLOY_REVISION": "2026-05-23-ev-fleet"
    }
  },
  "redirects": [
    {
      "source": "/roi",
      "destination": "https://www.bharatgig.live/investors",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "bharatgig.live" }],
      "destination": "https://www.bharatgig.live/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon\\.svg|site\\.webmanifest|robots\\.txt|sitemap\\.xml)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
