# Copy to apps/worker/.env.local — never commit real values.
# Set the same keys in Vercel → Project → Environment Variables → Production.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_ref

VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID=

# Optional: enable investor demo data on production (default: off on app.bharatgig.live)
VITE_ALLOW_INVESTOR_DEMO=false
