# Copy to apps/worker/.env.local — never commit real values.
# Set the same keys in Vercel → Project → Environment Variables → Production.

VITE_SUPABASE_URL=https://jsdmmskzwnqhmxboergf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_or_publishable_key
VITE_SUPABASE_PROJECT_ID=jsdmmskzwnqhmxboergf

# Open map stack (MapLibre + OpenStreetMap — zero Google cost)
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark
VITE_MAP_DEFAULT_LAT=12.9716
VITE_MAP_DEFAULT_LNG=77.5946
VITE_MAP_DEFAULT_ZOOM=12

# Optional: enable investor demo data on production (default: off on app.bharatgig.live)
VITE_ALLOW_INVESTOR_DEMO=false

